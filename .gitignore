# Workspace runtime data
/workspaces/*/jobs/
/workspaces/*/recorded_data/
/workspaces/*/.yadof/surrogate/
/workspaces/*/.yadof/logs/
/workspaces/*/.yadof/tool_output/*
!/workspaces/*/.yadof/tool_output/parameter_history/
!/workspaces/*/.yadof/tool_output/parameter_history/*.py

# Disposable task-specific work
/temp/*
!/temp/.gitkeep

# Python package and test artifacts
/build/
/dist/
/*.egg-info/
/src/*.egg-info/
/tests/_pytest_tmp*/
/tests/_tmp_runtime/
/tests/_contract_tmp/
/tests/_installed_env/
/tests/_build_deps/
__pycache__/
*.py[cod]
